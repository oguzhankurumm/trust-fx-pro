# ─── Database ─────────────────────────────────────────────────────────────────
# Local (Docker): postgresql://postgres:postgres@localhost:5432/trustfx
# Vercel/Production: use a managed Postgres (Neon, Supabase, Railway, etc.)
DATABASE_URL="postgresql://user:password@host:5432/trustfx"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-random-32-char-string"
NEXTAUTH_URL="https://trustfxpro.com.tr"
APP_BASE_URL="https://trustfxpro.com.tr"

# ─── CoinGecko API ────────────────────────────────────────────────────────────
# Free Demo key: https://www.coingecko.com/en/api (register for free)
COINGECKO_API_KEY="CG-your-demo-api-key-here"
# "demo" for free tier, "pro" for paid Pro plan
COINGECKO_API_TYPE="demo"

# ─── Google OAuth (optional) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
