// TrustFX Pro — Prisma Schema
// Compatible with PostgreSQL 14+ (Neon, Supabase, Render, Docker)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  BLOCKED
}

enum LedgerType {
  ADJUSTMENT  // admin manual adjustment (always APPROVED)
  DEPOSIT     // user deposit request
  WITHDRAWAL  // user withdrawal request
  TRADE       // crypto binary-option trade (bet deduction or win payout)
}

enum TradeDirection {
  UP
  DOWN
}

enum TradeResult {
  PENDING
  WIN
  LOSS
}

enum LedgerStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum Currency {
  TRY
  USDT
}

// ─── Core Models ──────────────────────────────────────────────────────────────

model User {
  id            String     @id @default(cuid())
  // NextAuth required fields
  name          String?
  email         String     @unique
  emailVerified DateTime?
  image         String?
  // TrustFX custom fields
  passwordHash  String?    // null for OAuth-only users
  role          Role       @default(USER)
  status        UserStatus @default(ACTIVE)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // Relations
  profile        Profile?
  ledgerEntries  LedgerEntry[]
  cryptoTrades   CryptoTrade[]
  adminActions   AdminAudit[]   @relation("AdminActions")
  targetAudits   AdminAudit[]   @relation("TargetUser")
  bankAccounts   BankAccount[]  @relation("AdminBankAccounts")
  // NextAuth adapter relations
  accounts       Account[]
  sessions       Session[]

  @@map("users")
}

model Profile {
  id     String  @id @default(cuid())
  userId String  @unique
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name   String?
  phone  String?

  @@map("profiles")
}

/// Immutable ledger — never delete or mutate rows; only add new ones.
/// Balance is derived: SUM(amount) WHERE status = APPROVED
model LedgerEntry {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      LedgerType
  /// Positive = credit, Negative = debit
  amount    Decimal      @db.Decimal(18, 2)
  currency  Currency     @default(TRY)
  status    LedgerStatus @default(PENDING)
  /// Free-form JSON: { note, txHash, adminReason, ... }
  metadata  Json?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([userId, status])
  @@index([userId, createdAt])
  @@map("ledger_entries")
}

/// Immutable audit trail — one row per admin action, never edited.
model AdminAudit {
  id           String   @id @default(cuid())
  adminId      String
  admin        User     @relation("AdminActions", fields: [adminId], references: [id])
  actionType   String   // e.g. BALANCE_ADJUST, APPROVE_DEPOSIT, BLOCK_USER …
  targetUserId String?
  targetUser   User?    @relation("TargetUser", fields: [targetUserId], references: [id])
  /// Full payload snapshot for forensics
  payload      Json
  createdAt    DateTime @default(now())

  @@index([adminId])
  @@index([targetUserId])
  @@map("admin_audits")
}

// ─── Crypto Trade Model ───────────────────────────────────────────────────────

/// Binary-option style crypto trades. Each trade deducts betAmount immediately;
/// a WIN creates a positive TRADE ledger entry equal to betAmount * WIN_MULTIPLIER.
model CryptoTrade {
  id          String         @id @default(cuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol      String         // e.g. "BTC", "ETH"
  direction   TradeDirection
  /// Price at trade entry (TRY)
  entryPrice  Decimal        @db.Decimal(18, 6)
  /// Price at trade resolution (TRY); null while PENDING
  exitPrice   Decimal?       @db.Decimal(18, 6)
  /// Amount the user bet (TRY)
  betAmount   Decimal        @db.Decimal(18, 2)
  /// Net payout on WIN (betAmount * multiplier); null on LOSS
  payout      Decimal?       @db.Decimal(18, 2)
  /// Duration in seconds chosen by user
  duration    Int
  result      TradeResult    @default(PENDING)
  resolvedAt  DateTime?
  createdAt   DateTime       @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([result])
  @@map("crypto_trades")
}

// ─── Bank Account Model ───────────────────────────────────────────────────────

/// Admin-managed bank accounts displayed to users during deposit (havale/EFT/FAST)
model BankAccount {
  id            String   @id @default(cuid())
  bankName      String
  iban          String   @unique
  accountHolder String
  swiftCode     String?
  isActive      Boolean  @default(true)
  adminId       String
  admin         User     @relation("AdminBankAccounts", fields: [adminId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive])
  @@map("bank_accounts")
}

// ─── NextAuth Prisma Adapter Models ──────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
